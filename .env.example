# ============================================================================
# Drawink Environment Configuration Template
# ============================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values in .env.local
# 3. .env.local is gitignored and should never be committed
# ============================================================================

# ----------------------------------------------------------------------------
# CLERK AUTHENTICATION
# ----------------------------------------------------------------------------
# Get these from: https://dashboard.clerk.com
# Frontend (public key - safe to expose in browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# CONVEX BACKEND
# ----------------------------------------------------------------------------
# Auto-generated when you run: npx convex dev
# Dashboard: https://dashboard.convex.dev
VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment

# ----------------------------------------------------------------------------
# FIREBASE STORAGE (Files only - database is in Convex)
# ----------------------------------------------------------------------------
# Get from: Firebase Console > Project Settings > Your apps > Web app
# JSON format required
VITE_APP_FIREBASE_CONFIG='{"apiKey":"","projectId":"","storageBucket":""}'

# ----------------------------------------------------------------------------
# COLLABORATION SERVER
# ----------------------------------------------------------------------------
# WebSocket server for real-time collaboration
# Dev: http://localhost:3003 | Prod: https://collab.drawink.app
VITE_APP_WS_SERVER_URL=http://localhost:3003

# ----------------------------------------------------------------------------
# AI CONFIGURATION
# ----------------------------------------------------------------------------
# AI backend for text-to-diagram, diagram-to-code features
# Dev: http://localhost:3015 | Prod: https://ai.drawink.app
VITE_APP_AI_BACKEND=http://localhost:3015

# AI Provider (OpenAI-compatible API — used by Convex server-side actions)
# Supports any OpenAI-compatible provider: Gemini, OpenAI, Groq, Together, etc.
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai
# OpenAI: https://api.openai.com/v1
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=your-api-key-here
AI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# STRIPE BILLING (Optional)
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_ID_TEAM=price_xxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# APP FLAGS
# ----------------------------------------------------------------------------
VITE_APP_GIT_SHA=development
VITE_APP_ENABLE_TRACKING=false
VITE_APP_DISABLE_PREVENT_UNLOAD=true
VITE_APP_DISABLE_PWA=true
VITE_APP_DISABLE_SENTRY=true
VITE_APP_DEBUG_ENABLE_TEXT_CONTAINER_BOUNDING_BOX=false

# ----------------------------------------------------------------------------
# SENTRY ERROR TRACKING (Optional)
# ----------------------------------------------------------------------------
# Get from: https://sentry.io
VITE_SENTRY_DSN=
