rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Workspaces - users can manage their own workspaces
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Boards - users can manage boards in their workspaces
    match /boards/{boardId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Default rules for other collections (shareable links, etc.)
    match /{document=**} {
      allow get, write: if true;
      // never set this to true, otherwise anyone can delete anyone else's drawing.
      allow list: if false;
    }
  }
}
